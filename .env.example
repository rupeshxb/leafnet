# Copy this file to .env for local development. Never commit .env to git.

# Flask secret key — change to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Set to 1 for local dev, 0 (or omit) for production
FLASK_DEBUG=1

# Port — Render sets this automatically; leave as 5000 for local
PORT=5000

# Max upload size in bytes (default: 10 MB)
MAX_CONTENT_LENGTH=10485760

# Suppress TensorFlow GPU/CUDA warnings on CPU-only machines
TF_CPP_MIN_LOG_LEVEL=3
CUDA_VISIBLE_DEVICES=-1
